{
  "$schema": "https://raw.githubusercontent.com/TitusKirch/skills/main/tituskirch-skills.schema.json",
  "language": "en",
  "pr": {
    "backend": "github",
    "base": "dev",
    "title": {
      "convention": "conventional"
    }
  },
  "issue": {
    "backend": "github",
    "title": {
      "convention": "plain"
    },
    "labels": {
      "exclude": ["stack:*", "autorelease:*", "dependencies"]
    },
    "github": {
      "template": null
    }
  },
  "docs": {
    "preset": "cli"
  },
  "work": {
    "verify": "pnpm check && pnpm typecheck && pnpm test && pnpm build",
    "labels": {
      "ready": "ai: ready",
      "working": "ai: working",
      "review": "ai: review",
      "done": "ai: done",
      "blocked": "ai: blocked"
    },
    "priorityLabels": [
      "priority: urgent",
      "priority: high",
      "priority: medium",
      "priority: low"
    ]
  }
}
