{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "forgemap",
  "version": "0.1.0",
  "description": "CLI that manages a local repo layout under ~/projects/<gitserver>/<org>/<repo>.",
  "keywords": [
    "cli",
    "developer-tools",
    "forge",
    "gh",
    "git",
    "github",
    "nodejs",
    "repository-management"
  ],
  "homepage": "https://github.com/TitusKirch/forgemap#readme",
  "bugs": {
    "url": "https://github.com/TitusKirch/forgemap/issues"
  },
  "license": "MIT",
  "author": "Titus Kirch <titus.kirch@kirch.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TitusKirch/forgemap.git"
  },
  "bin": {
    "forgemap": "./dist/bin/forgemap.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config/define.d.ts",
      "import": "./dist/config/define.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm format",
    "check:fix": "pnpm lint:fix && pnpm format:fix",
    "taze": "taze",
    "taze:w": "taze -w",
    "prepare": "husky"
  },
  "dependencies": {
    "c12": "^3.0.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "defu": "^6.1.4",
    "pathe": "^2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "taze": "^19.13.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2"
}
